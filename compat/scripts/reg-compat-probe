#!/bin/sh
# reg-compat-probe — Probe hardware features and write a local compat report.
# Runs at boot and on hardware events (WiFi connect, BT pair, HDMI plug, etc.)
# Merges results into /userdata/system/.compat-report.json
# No network required.
#
# Usage:
#   reg-compat-probe              # full probe (boot)
#   reg-compat-probe --wifi       # re-probe WiFi only
#   reg-compat-probe --bluetooth  # re-probe Bluetooth only
#   reg-compat-probe --hdmi       # re-probe HDMI
#   reg-compat-probe --suspend    # mark suspend as working (called on resume)
#   reg-compat-probe --usb        # re-probe USB

# Opt-out: if user sets compat.reporting=0 in system.conf, do nothing
CONF_FILE="/userdata/system/system.conf"
if [ -f "$CONF_FILE" ]; then
    OPT_OUT=$(awk -F= '/^[[:space:]]*compat\.reporting[[:space:]]*=/ { gsub(/[[:space:]]/, "", $2); print $2 }' "$CONF_FILE")
    if [ "$OPT_OUT" = "0" ]; then
        exit 0
    fi
fi

REPORT_FILE="/userdata/system/.compat-report.json"
BOARD_FILE="/boot/boot/system.board"
VERSION_FILE="/usr/share/reglinux/system.version"
ARCH_FILE="/usr/share/reglinux/system.arch"

# --- Helpers ---

probe_result() {
    # $1 = feature_id, $2 = status (works/broken/partial)
    FEATURE="$1"
    STATUS="$2"
    # Store in a temp var — will be merged into JSON later
    eval "PROBE_${FEATURE}=${STATUS}"
}

check_sysfs_exists() {
    # Returns 0 if any match found
    ls $1 >/dev/null 2>&1
}

# --- Gather system info ---

DEVICE_ID=""
[ -f "$BOARD_FILE" ] && DEVICE_ID=$(cat "$BOARD_FILE" 2>/dev/null)

ARCH=$(uname -m 2>/dev/null)
KERNEL=$(uname -r 2>/dev/null)

REG_VERSION=""
[ -f "$VERSION_FILE" ] && REG_VERSION=$(cat "$VERSION_FILE" 2>/dev/null | head -1)
REG_VERSION="${REG_VERSION%% *}"  # strip timestamp

# Build date in ISO format YYYY-MM-DD
# Try to derive from REG version (e.g. "26.03-dev-abc123" → "2026-03-01")
RAW_VER=$(echo "$REG_VERSION" | grep -oE '[0-9]{2}\.[0-9]{2}' | head -1)
if [ -n "$RAW_VER" ]; then
    YEAR="20$(echo "$RAW_VER" | cut -d. -f1)"
    MONTH="$(echo "$RAW_VER" | cut -d. -f2)"
    BUILD_DATE="${YEAR}-${MONTH}-01"
else
    BUILD_DATE=$(date +%Y-%m-%d)
fi

# System UUID (machine-id, or generate one)
if [ -f /etc/machine-id ]; then
    SYSTEM_UUID=$(cat /etc/machine-id)
elif [ -f /userdata/system/.machine-id ]; then
    SYSTEM_UUID=$(cat /userdata/system/.machine-id)
else
    SYSTEM_UUID=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || date +%s | sha256sum | cut -d' ' -f1)
    mkdir -p /userdata/system
    echo "$SYSTEM_UUID" > /userdata/system/.machine-id
fi

# Board file hash (for attestation)
BOARD_HASH=""
[ -f "$BOARD_FILE" ] && BOARD_HASH=$(sha256sum "$BOARD_FILE" 2>/dev/null | cut -d' ' -f1)

# --- Probe functions ---

probe_boot() {
    # If this script is running, boot works
    probe_result boot works
}

probe_display() {
    if check_sysfs_exists "/sys/class/drm/card*/enabled" || check_sysfs_exists "/sys/class/graphics/fb*"; then
        probe_result display works
    fi
    # Backlight = internal display
    if check_sysfs_exists "/sys/class/backlight/*/brightness"; then
        probe_result display works
    fi
}

probe_hdmi() {
    # Check for HDMI connector
    for connector in /sys/class/drm/card*-HDMI-*; do
        [ -d "$connector" ] || continue
        STATUS=$(cat "$connector/status" 2>/dev/null)
        if [ "$STATUS" = "connected" ]; then
            probe_result hdmi_out works
            # Check HDMI audio
            if aplay -l 2>/dev/null | grep -qi "hdmi\|dp\|display"; then
                probe_result hdmi_audio works
            fi
            return
        fi
    done
}

probe_audio() {
    if [ -f /proc/asound/cards ] && [ "$(cat /proc/asound/cards | wc -l)" -gt 0 ]; then
        # At least one sound card exists
        CARDS=$(cat /proc/asound/cards | grep -c '^\s*[0-9]')
        if [ "$CARDS" -gt 0 ]; then
            probe_result audio works
        fi
    fi
}

probe_wifi() {
    if check_sysfs_exists "/sys/class/net/wlan*"; then
        # WiFi interface exists
        # Check if it's actually up and associated
        for iface in /sys/class/net/wlan*; do
            [ -d "$iface" ] || continue
            OPERSTATE=$(cat "$iface/operstate" 2>/dev/null)
            if [ "$OPERSTATE" = "up" ]; then
                probe_result wifi works
                return
            fi
        done
        # Interface exists but not connected — partial (driver works, can't confirm full function)
        probe_result wifi partial
    else
        # No WiFi interface at all — check if hardware exists but driver failed
        if lspci 2>/dev/null | grep -qi "wifi\|wireless\|wlan" || \
           lsusb 2>/dev/null | grep -qi "wifi\|wireless\|wlan"; then
            probe_result wifi broken
        fi
        # else: no WiFi hardware, will be N/A (handled by server)
    fi
}

probe_bluetooth() {
    if check_sysfs_exists "/sys/class/bluetooth/hci*"; then
        # BT controller exists
        if hciconfig hci0 2>/dev/null | grep -q "UP RUNNING"; then
            probe_result bluetooth works
        else
            probe_result bluetooth partial
        fi
    fi
}

probe_ethernet() {
    for iface in /sys/class/net/eth* /sys/class/net/en*; do
        [ -d "$iface" ] || continue
        probe_result ethernet works
        return
    done
}

probe_usb_host() {
    # Count non-root-hub USB devices
    USB_DEVICES=$(ls /sys/bus/usb/devices/ 2>/dev/null | grep -v '^usb' | grep -cv ':')
    if [ "$USB_DEVICES" -gt 0 ]; then
        probe_result usb_host works
    elif check_sysfs_exists "/sys/bus/usb/devices/usb*"; then
        # Root hub exists = host controller works
        probe_result usb_host works
    fi
}

probe_usb_otg() {
    if check_sysfs_exists "/sys/class/udc/*"; then
        probe_result usb_otg works
    fi
}

probe_sd_card() {
    if check_sysfs_exists "/sys/block/mmcblk*"; then
        probe_result sd_card works
    fi
}

probe_battery() {
    for ps in /sys/class/power_supply/*; do
        [ -d "$ps" ] || continue
        TYPE=$(cat "$ps/type" 2>/dev/null)
        if [ "$TYPE" = "Battery" ]; then
            CAPACITY=$(cat "$ps/capacity" 2>/dev/null)
            if [ -n "$CAPACITY" ] && [ "$CAPACITY" -ge 0 ] 2>/dev/null; then
                probe_result battery works
                return
            fi
        fi
    done
}

probe_suspend() {
    if [ -f /sys/power/state ]; then
        if grep -q "mem" /sys/power/state 2>/dev/null; then
            probe_result suspend works
        fi
    fi
}

probe_thermal() {
    for tz in /sys/devices/virtual/thermal/thermal_zone*/temp; do
        [ -f "$tz" ] || continue
        TEMP=$(cat "$tz" 2>/dev/null)
        if [ -n "$TEMP" ] && [ "$TEMP" -gt 0 ] 2>/dev/null; then
            probe_result thermal works
            return
        fi
    done
}

probe_gpu() {
    # Check for DRI render device
    if check_sysfs_exists "/dev/dri/renderD*" || check_sysfs_exists "/dev/dri/card*"; then
        probe_result gpu_accel works
    fi

    # Vulkan
    if [ -x /usr/bin/vulkaninfo ]; then
        if vulkaninfo --summary 2>/dev/null | grep -q "deviceName"; then
            probe_result vulkan works
        fi
    fi

    # OpenGL ES — if we're running the UI, it works
    if check_sysfs_exists "/dev/dri/renderD*"; then
        probe_result gles works
    fi
}

probe_controllers() {
    # Check for gamepad/joystick input devices
    for ev in /sys/class/input/event*/device/name; do
        [ -f "$ev" ] || continue
        NAME=$(cat "$ev" 2>/dev/null)
        case "$NAME" in
            *pad*|*joy*|*controller*|*gamepad*|*Xbox*|*PS*|*Nintendo*)
                probe_result buttons works
                probe_result analog_sticks works
                # Check force feedback (rumble)
                EVDEV=$(dirname $(dirname "$ev"))
                if check_sysfs_exists "$EVDEV/device/ff*"; then
                    probe_result rumble works
                fi
                # Check hotplug — if we found it, hotplug works
                probe_result controller_hotplug works
                return
                ;;
        esac
    done
}

# --- Run probes ---

MODE="${1:-full}"

case "$MODE" in
    --wifi)
        probe_wifi
        ;;
    --bluetooth)
        probe_bluetooth
        ;;
    --hdmi)
        probe_hdmi
        ;;
    --suspend)
        # Called on resume — if we got here, suspend works
        probe_result suspend works
        ;;
    --usb)
        probe_usb_host
        probe_usb_otg
        probe_controllers
        ;;
    full|*)
        probe_boot
        probe_display
        probe_hdmi
        probe_audio
        probe_wifi
        probe_bluetooth
        probe_ethernet
        probe_usb_host
        probe_usb_otg
        probe_sd_card
        probe_battery
        probe_suspend
        probe_thermal
        probe_gpu
        probe_controllers
        ;;
esac

# --- Merge results into JSON report ---

mkdir -p "$(dirname "$REPORT_FILE")"

# Read existing report if any
OLD_RESULTS=""
if [ -f "$REPORT_FILE" ]; then
    OLD_RESULTS=$(cat "$REPORT_FILE")
fi

# Build new JSON — merge old results with new probes
# Features list
ALL_FEATURES="boot rescue_mode display hdmi_out audio hdmi_audio wifi bluetooth ethernet usb_host usb_otg sd_card suspend thermal battery buttons analog_sticks controller_hotplug rumble gpu_accel vulkan gles"

# Start JSON
{
    printf '{\n'
    printf '  "device_id": "%s",\n' "$DEVICE_ID"
    printf '  "arch": "%s",\n' "$ARCH"
    printf '  "kernel": "%s",\n' "$KERNEL"
    printf '  "reg_version": "%s",\n' "$REG_VERSION"
    printf '  "build_date": "%s",\n' "$BUILD_DATE"
    printf '  "system_uuid": "%s",\n' "$SYSTEM_UUID"
    printf '  "board_file_hash": "%s",\n' "$BOARD_HASH"
    printf '  "probed_at": "%s",\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf '  "results": {\n'

    FIRST=1
    for feat in $ALL_FEATURES; do
        # Check if we have a new probe result for this feature
        eval "NEW_VAL=\${PROBE_${feat}:-}"

        # If no new result, try to keep the old one
        if [ -z "$NEW_VAL" ] && [ -n "$OLD_RESULTS" ]; then
            # Extract old value from JSON — only if it's a quoted string (skip null)
            OLD_VAL=$(echo "$OLD_RESULTS" | grep "\"${feat}\"" | sed -n 's/.*: *"\([^"]*\)".*/\1/p' | head -1)
            # Trim whitespace and reject empty/null values
            OLD_VAL=$(printf '%s' "$OLD_VAL" | tr -d '[:space:]')
            case "$OLD_VAL" in
                works|partial|broken|na|untested) NEW_VAL="$OLD_VAL" ;;
                *) NEW_VAL="" ;;
            esac
        fi

        [ "$FIRST" = "1" ] && FIRST=0 || printf ',\n'

        if [ -n "$NEW_VAL" ]; then
            printf '    "%s": "%s"' "$feat" "$NEW_VAL"
        else
            printf '    "%s": null' "$feat"
        fi
    done

    printf '\n  }\n'
    printf '}\n'
} > "$REPORT_FILE"

# Log
logger -t reg-compat-probe "Probe complete (mode=$MODE, device=$DEVICE_ID)"
