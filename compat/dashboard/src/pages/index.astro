---
import '../styles/global.css';
import { Matrix } from '../components/Matrix';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>REG-Linux Compatibility Matrix</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Hardware compatibility tracking for REG-Linux retrogaming OS — 186 devices across ARM, AArch64, RISC-V, and x86_64." />
    <link rel="icon" href="https://reglinux.org/assets/images/favicon.ico" />
  </head>
  <body>
    <header>
      <a href="https://reglinux.org" class="site-logo">
        <img src="https://reglinux.org/assets/images/reg_linux_logo-sm.webp" alt="REG-Linux" />
      </a>
      <span class="separator">/</span>
      <span class="page-title">Compatibility Matrix</span>
      <nav>
        <a href="https://reglinux.org">Home</a>
        <a href="https://reglinux.org/wiki">Wiki</a>
        <a href="/">Matrix</a>
      </nav>
    </header>
    <main>
      <Matrix client:only="react" />
    </main>
  </body>
</html>
